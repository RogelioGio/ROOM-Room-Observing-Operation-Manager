<%= form_with(model: building, class: "contents") do |form| %>
  <% if building.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(building.errors.count, "error") %> prohibited this building from being saved:</h2>

      <ul class="list-disc ml-6">
        <% building.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

    <div class="h-full flex justify-center">
      <div class="w-4xl gap-x-6 gap-y-4">

      <div class="my-5">
        <%= form.label :name %>
        <%= form.text_field :name, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": building.errors[:name].none?, "border-red-400 focus:outline-red-600": building.errors[:name].any?}] %>
      </div>

      <div class="my-5">
        <%= form.label :address %>
        <%= form.text_field :address, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": building.errors[:address].none?, "border-red-400 focus:outline-red-600": building.errors[:address].any?}] %>
      </div>

      <div class="inline">
        <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
      </div>
    </div>
  </div>
<% end %>
