<% content_for :title, "New building" %>

  <div class="w-full flex flex-col gap-6 h-full">
    <div class="flex flex-row items-center justify-between w-full">
        <div class="flex items-center gap-3">
          <%= link_to buildings_path, class: "" do %>
              <%= lucide_icon "arrow-left", class: "size-7" %>
          <% end %>
          <div class="bg-blue-100 text-blue-400 rounded-md size-14 inline-flex items-center justify-center">
            <%= lucide_icon "building-2", class: "size-7" %>
          </div>
          <div>
            <p class="font-bold text-xl">Add New Building</p>
            <p class="text-xs text-stone-900/70">Complete the form and add new building in the system</p>
        </div>
        </div>
    </div>

    <%= render "form", building: @building %>

  </div>