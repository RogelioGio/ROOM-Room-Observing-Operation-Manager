<!DOCTYPE html>
<html data-theme="light"> 
  <head>
    <title><%= content_for(:title) || "Room Project" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Room Project">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= action_cable_meta_tag %>
  </head>

  <body >
    <div class="flex min-h-screen min-w-screen bg-slate-50 text-slate-900">
      <aside class="w-64 bg-slate-900 text-white flex-shrink-0 flex flex-col">
        <div class="p-6 text-2xl font-black tracking-tight border-b border-slate-800 text-center">
          <p>ROOM<span class="text-blue-400"> Project</span></p>
        </div>
        <nav class="flex-grow p-4 space-y-2">
          <%= link_to new_building_path, class: "flex items-center justify-center w-full space-x-2 py-3 px-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl shadow-lg transition-all transform active:scale-95" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            <span>Add Building</span>
          <% end %>
          <%= link_to root_path, class: "flex items-center space-x-3 p-3 rounded-lg transition #{current_page?(root_path) ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 text-slate-400'}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            <span>Dashboard</span>
          <% end %>
          <%= link_to buildings_path, class: "flex items-center space-x-3 p-3 rounded-lg transition #{current_page?(buildings_path) ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 text-slate-400'}" do %>
             <%= lucide_icon "building-2", class: "size-5" %>
            <span>All Buildings</span>
          <% end %>
          <p class="text-sm">Buildings</p>
          <% @sidebar_buildings.each do |building| %>
            <%= link_to building_path(building), class: "flex items-center space-x-3 p-3 rounded-lg transition #{current_page?(building_path(building)) ? 'bg-blue-600 text-white' : 'hover:bg-slate-800 text-slate-400'}" do %>
               <%= lucide_icon "building", class: "size-5" %>
              <span><%= building.name %></span>
            <% end %>
          <% end %>
        </nav>
      </aside>
      <div class="w-full h-screen p-6 overflow-y-auto">
          <%= yield %>
      </div>
    </div>
    <%= render "shared/flash" %>
    <%= turbo_frame_tag "modal" %>
  </body>
</html>
