<%= form_with(model: schedule, class: "contents") do |form| %>
  <% if schedule.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(schedule.errors.count, "error") %> prohibited this schedule from being saved:</h2>

      <ul class="list-disc ml-6">
        <% schedule.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="h-full flex justify-center">
    <div data-controller="date-range" class="grid grid-cols-2 grid-rows-[min-content_min-content_min-content_min-content_min-content] w-4xl gap-x-6 gap-y-4">
        <div class="flex flex-col gap-2">
          <p class="text-sm">Start Date</p>
          <%= form.date_field :start_date, min: Date.today.to_s, class: "input input-bordered w-full", data: { date_range_target: "start", action: "input->date-range#handleDateChange" }%>
        </div>
        <div class="flex flex-col gap-2">
          <p class="text-sm">End Date</p>
          <%= form.date_field :end_date, min: Date.today.to_s, class: "input input-bordered w-full", data: { date_range_target: "end", action: "input->date-range#handleDateChange" } %>
        </div>
        <div class="col-span-2 flex flex-col gap-2">
            <p class="text-sm">Frequency</p>
            <div class="grid grid-cols-2 gap-y-4 gap-x-6">
              <% ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'].each do |day| %>
                <label class="inline-flex items-center gap-2">
                  <input type="checkbox" 
                        name="schedule[frequency][]" 
                        value="<%= day %>" 
                        class="checkbox checkbox-info checkbox-md" 
                        data-date-range-target="checkbox" 
                        <%= "checked" if @schedule.frequency_list.include?(day) %>/>
                  <span class=""><%= day %></span>
                </label>
              <% end %>
            </div>
        </div>
        <div class="flex flex-col gap-2">
          <p class="text-sm">Start Time</p>
          <%= form.time_field :start_time, 
              class: "input input-bordered w-full", 
              data: { 
                date_range_target: "startTime", 
                action: "input->date-range#handleTimeChange" 
              } %>
        </div>
        <div class="flex flex-col gap-2">
          <p class="text-sm">End Time</p>
          <%= form.time_field :end_time, 
              class: "input input-bordered w-full", 
              data: { 
                date_range_target: "endTime", 
                action: "input->date-range#handleTimeChange" 
              } %>
        </div>
        <div class="col-span-2 flex flex-col gap-2">
            <p class="text-sm">Status</p>
            <%= form.select :status, options_for_select([['Active', 'active'], ['Inactive', 'inactive']]), { prompt: "Select Status" }, { class: "select select-bordered w-full" } %>
        </div>
        <div class="col-span-2 flex flex-col gap-2">
            <p class="text-sm">Description</p>
            <%= form.text_area :description, class: "input input-bordered w-full p-4 h-24" %>
        </div>
          <%= form.hidden_field :room_id, value: @room.id %>
        <div>
          <%= form.submit class: "rounded-md px-3.5 py-2.5 text-white bg-blue-600 hover:bg-blue-500 font-medium cursor-pointer transition" do %>
            <%= lucide_icon "save", class: "size-4" %>
            <span>Save</span>
          <% end %>
        </div>
    </div>
  </div>
 
<% end %>
