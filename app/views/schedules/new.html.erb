<% content_for :title, "New schedule" %>

<div class="w-full h-full flex flex-col gap-6">
  
  <div class="flex flex-row items-center justify-between w-full">
    <div class="flex items-center gap-3">
      <%= link_to "#", onclick: "history.back(); return false;", class: "" do %>
        <%= lucide_icon "arrow-left", class: "size-7" %>
      <% end %>
      <div class="bg-blue-100 text-blue-400 rounded-md size-14 inline-flex items-center justify-center">
        <%= lucide_icon "warehouse", class: "size-7" %>
      </div>
      <div>
          <p class="text-xs text-stone-900/70">Room Name</p>
          <p class="font-bold text-xl"><%= @room.name %></p>
          <p class="text-xs"><%= @room.building.name %></p>
      </div>
      <div>
         <% case @room.status %>
            <% when "available" %>
              <div class="badge badge-soft badge-primary">
                <%= lucide_icon "circle", class: "size-3" %>
                <span>Available</span>
              </div>
            <% when "occupied" %>
              <div class="badge badge-soft badge-error">
                <%= lucide_icon "ban", class: "size-3" %>
                <span>Occupied</span>
              </div>
            <% when "maintenance" %>
              <div class="badge badge-soft badge-warning">
                <%= lucide_icon "wrench", class: "size-3" %>
                <span>Maintenance</span>
              </div>
            <% else %>
              <span class="bg-gray-100 text-gray-800 px-2 py-1 rounded">Unknown</span>
          <% end %>
      </div>
    </div>
    <div class="text-right">
      <p class="font-bold text-xl">Create Schedule</p>
      <p class="text-xs">Fill out the form to create a schedule</p>
    </div>
  </div>

  <%= render "form", schedule: @schedule %>
</div>
